generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REWORK
}

enum ProgressStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum UOMType {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  role          Role

  managerId     String?
  manager       User?    @relation("ManagerEmployees", fields: [managerId], references: [id])

  employees     User[]   @relation("ManagerEmployees")

  goalSheets    GoalSheet[]
  checkIns      CheckIn[]
  auditLogs     AuditLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GoalSheet {
  id            String      @id @default(uuid())
  employeeId    String
  employee      User        @relation(fields: [employeeId], references: [id])

  status        GoalStatus  @default(DRAFT)
  isLocked      Boolean     @default(false)
  totalWeight   Int

  submittedAt   DateTime?
  approvedAt    DateTime?

  goals         Goal[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Goal {
  id              String      @id @default(uuid())

  goalSheetId     String
  goalSheet       GoalSheet   @relation(fields: [goalSheetId], references: [id])

  thrustArea      String
  title            String
  description      String

  uomType         UOMType
  target          Float
  weightage       Int

  isShared        Boolean     @default(false)
  sharedGoalId    String?

  quarterlyUpdates QuarterlyUpdate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuarterlyUpdate {
  id                String          @id @default(uuid())

  goalId            String
  goal              Goal            @relation(fields: [goalId], references: [id])

  quarter           String
  achievement       Float
  progressStatus    ProgressStatus

  score             Float?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CheckIn {
  id              String      @id @default(uuid())

  managerId       String
  manager         User        @relation(fields: [managerId], references: [id])

  employeeId      String
  goalSheetId     String

  comment         String

  quarter         String

  createdAt       DateTime @default(now())
}

model AuditLog {
  id              String      @id @default(uuid())

  userId          String
  user            User        @relation(fields: [userId], references: [id])

  action          String
  entity          String
  entityId        String

  oldValue        String?
  newValue        String?

  createdAt       DateTime @default(now())
}